{
  "name": "waisify-spotify-clone",
  "version": "1.0.0",
  "description": "Premium Spotify Clone for Windows with YouTube streaming",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "tsc && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "vite build",
    "build:electron": "tsc",
    "build": "npm run build:renderer && npm run build:electron"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.4.6",
    "typescript": "^5.3.3",
    "vite": "^5.1.4"
  }
}
